{
  "scenarios": [
    {
      "name": "owasp_review_requires_reference_search_before_final",
      "prompt": "security audit app.py using OWASP",
      "arguments": {
        "path": "app.py"
      },
      "expected_skill": "owasp_security_review",
      "expected_resolved_task_type": "owasp_security_review",
      "must_recommend_tools": [
        "discover_review_targets"
      ],
      "must_allow_tools": [
        "discover_review_targets",
        "search_owasp_reference"
      ],
      "skills": [
        {
          "name": "owasp_security_review",
          "description": "Review code for security issues using OWASP references.",
          "category": "code",
          "tags": ["owasp", "security", "audit", "review", "code", "python"],
          "supported_actions": ["review"],
          "supported_domains": ["code"],
          "supported_filetypes": ["py"],
          "required_args": ["path"],
          "parameters": {
            "type": "object",
            "properties": {
              "path": {"type": "string"}
            },
            "required": ["path"],
            "additionalProperties": false
          },
          "tools_required": [
            "discover_review_targets",
            "read_file_with_line_numbers",
            "search_owasp_reference"
          ],
          "default_score": 0.7
        }
      ],
      "tool_sequence": [
        {
          "tool": "discover_review_targets",
          "arguments": {"root": "app.py", "max_files": 20},
          "expect": "allowed"
        }
      ],
      "final_answer": {
        "content": "Potential issue found. OWASP says this is risky.",
        "expect_blocked": true
      }
    },
    {
