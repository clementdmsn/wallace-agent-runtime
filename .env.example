# OpenAI-compatible local model server
WALLACE_MODEL_PROVIDER=local
WALLACE_BASE_URL=http://localhost:1234/v1
WALLACE_API_KEY=lmstudio
WALLACE_MODEL=unsloth/qwen3-4b-instruct-2507
WALLACE_EMBEDDING_MODEL=unsloth/qwen3-4b-instruct-2507

# Web server
WALLACE_HOST=127.0.0.1
WALLACE_PORT=8000
WALLACE_FLASK_DEBUG=false

# Runtime paths
WALLACE_PROJECT_DIR=.
WALLACE_SANDBOX_DIR=sandbox
WALLACE_CURL_WHITELIST_PATH=.local/curl_whitelist.json

# Skill catalog and generated indexes
WALLACE_SKILL_METADATA_DIR=skill_catalog/metadatas
WALLACE_SKILL_PROCEDURE_DIR=skill_catalog/procedures
WALLACE_SKILL_INDEX_DIR=skills/indexes
WALLACE_SKILL_STATS_FILENAME=skills.stats.json

# Agent limits and tracing
WALLACE_MAX_AUTO_TURNS=24
WALLACE_MAX_TOOL_OUTPUT=20000
WALLACE_TOOL_TIMEOUT=5
WALLACE_DONE_TOKEN=__DONE__
WALLACE_RUN_TRACE=true
WALLACE_RUN_TRACE_PAYLOADS=false
WALLACE_RUN_TRACE_DIR=logs/runs
